# ---- Supabase ----
# Project settings -> API. Use the SERVICE ROLE key (server only, never public).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- Gemini (Google AI Studio) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model that writes the hourly questions. pro is highest quality; drop to
# gemini-2.5-flash for lower cost and latency.
AGENT_MODEL=gemini-3.1-pro-preview

# ---- Telegram ----
# Create a bot with @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=
# The bot's username WITHOUT the @, used to build connect links (e.g. my_standup_bot).
TELEGRAM_BOT_USERNAME=
# Any random string. Telegram echoes it back so we can verify inbound calls.
# Generate one: openssl rand -hex 24
TELEGRAM_WEBHOOK_SECRET=

# ---- Email (optional second channel) ----
# Only needed if any teammate is reached by email. Provider: resend or sendgrid.
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
# Verified sender, e.g. "Standup <standup@yourdomain.com>".
EMAIL_FROM=
# Domain for plus-addressed reply routing, e.g. inbox.yourdomain.com.
# Replies then target task+<id>@inbox.yourdomain.com so they thread to the task.
EMAIL_REPLY_DOMAIN=
# Optional shared secret your provider sends on inbound posts (header
# X-Inbound-Secret or ?secret=). Leave blank to skip the check.
EMAIL_INBOUND_SECRET=

# Secret used to sign one-click email links (Done / Blocked / Snooze).
# Required if email is used. Generate: openssl rand -hex 24
ACTION_SECRET=

# ---- Cron ----
# Any random string. On Vercel, setting this env var makes Vercel send it as a
# Bearer token on cron runs automatically. Generate: openssl rand -hex 24
CRON_SECRET=

# ---- Dashboard ----
# The single password to open the dashboard.
DASHBOARD_PASSWORD=

# ---- App ----
# Your deployed url, used to build the Telegram webhook and connect links.
APP_URL=http://localhost:3000

# Fallback channel when a user's preference is 'auto' and neither Telegram nor
# email can be inferred. Rarely used. One of: telegram, email.
ACTIVE_TRANSPORT=telegram
